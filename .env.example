# Base URL of your backend API (no trailing slash required)
# Example: http://localhost:8000
VITE_API_BASE_URL=

# Optional: override paths if your backend routes are different
# If omitted, defaults are used:
# - /api/contact
# - /api/email-capture
VITE_CONTACT_API_PATH=/api/contact
VITE_EMAIL_CAPTURE_API_PATH=/api/email-capture

# Optional: default gateway to preselect in checkout UI
# Supported: razorpay | stripe
VITE_DEFAULT_PAYMENT_PROVIDER=razorpay

# ------------------------------------------------------------------------------
# Backend server environment (used by server/index.js)
# Copy to your backend runtime env (or place in .env for local dev)
# ------------------------------------------------------------------------------
# PORT=8000
# FRONTEND_ORIGIN=http://localhost:5173
# ASSET_BASE_URL=http://localhost:5173
# PUBLIC_API_BASE_URL=https://your-backend-domain
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# STRIPE_SECRET_KEY=sk_live_or_test_key
# STRIPE_WEBHOOK_SECRET=whsec_...
# RAZORPAY_KEY_ID=rzp_live_or_test_key
# RAZORPAY_KEY_SECRET=rzp_secret
# RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
